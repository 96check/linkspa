# Supabase – get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL – used for QR codes (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://linkspa.com

# Mapbox – for address autocomplete (https://account.mapbox.com/access-tokens/)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here